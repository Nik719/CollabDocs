# ==========================================
# CollabDocs Git Ignore Rules
# ==========================================

# --- Python / Django (backend) ---
**/venv/
**/.venv/
**/env/
**/ENV/
**/env.bak/
**/venv.bak/
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.egg-info/
**/.ruff_cache/
**/.pytest_cache/
**/.mypy_cache/
**/.tox/
**/.coverage
**/htmlcov/
**/.noseids
**/nosetests.xml
**/coverage.xml
**/*.cover
**/*.log

# Local databases and caches
**/db.sqlite3
**/db.sqlite3-journal
**/staticfiles/
**/media/

# --- Environment Configurations (Sensitive & Local) ---
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
!**/.env.example

# --- Node / Vite (frontend) ---
**/node_modules/
**/dist/
**/dist-ssr/
**/*.local
**/.eslintcache
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# --- Operating System Files ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.db

# --- IDEs / Editors ---
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# --- Development, Documentation & Testing Assets (Not required for production runtime) ---
# Project requirements details
/projectdetailspdf.pdf

# Postman collection at repo root (used only for development API testing)
/collabdocs_postman.json

# Local documentation files
/docs/

# Dev script folders and dev dependencies
/backend/scripts/
/backend/requirements-dev.txt
/backend/config/settings_test.py
/backend/api/tests/
