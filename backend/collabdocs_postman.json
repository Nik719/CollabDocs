  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('user_id', json.id);",
                  "    console.log('Set user_id =', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Alice\",\n  \"last_name\": \"Sharma\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"+911234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                ""
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                "{{user_id}}",
                ""
              ]
            }
          }
        }
      ]
    },
