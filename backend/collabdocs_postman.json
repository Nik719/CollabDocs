    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('workspace_id', json.id);",
                  "    console.log('Set workspace_id =', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering Team\",\n  \"owner\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workspaces/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "workspaces",
                ""
              ]
            }
          }
        },
        {
          "name": "List All Workspaces",
          "request": {
